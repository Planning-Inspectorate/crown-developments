{% extends "views/layouts/main.njk" %}

{% from "govuk/components/table/macro.njk" import govukTable %}

{% block pageHeading %}{% endblock %}

{% block pageContent %}
    <div class="govuk-width-container">
        <main class="govuk-main-wrapper" id="main-content">
            <div class="govuk-grid-row">
                <div class="govuk-grid-column-one-third">
                    <ul class="govuk-list">
                      <li>
                        <a class="govuk-link" href="/applications/application-information/{{ id }}">Application Information</a>
                      </li>
                      <br>
                      <li>
                        <strong>Documents</strong>
                      </li>
                      <br>
                      <li>
                        <a class="govuk-link" href="/applications/application-information/{{ id }}/have-your-say">Have your say</a>
                      </li>
                    </ul>
                </div>

                <div class="govuk-grid-column-two-thirds">
                    <div class="govuk-grid-row">
                        <div class="govuk-grid-column-full">
                            <h2 class="govuk-heading-l">
                                {{ pageTitle }}
                            </h2>

                            {% set documentRows = [] %}
                            {% for document in documents %}
                                {% set documentRows = (documentRows.push([
                                    {html: "<a class='govuk-link' href='" + baseUrl + "/" +  document.id +"' target='_blank'>" + document.name + "</a>"},
                                    {text: document.type},
                                    {text: document.lastModified},
                                    {text: document.size}
                                ]), documentRows) %}
                            {% endfor %}
                            {{ govukTable({
                                head: [
                                    {text: 'File'},
                                    {text: 'Type'},
                                    {text: 'Modified'},
                                    {text: 'Size'}
                                ],
                                rows: documentRows
                            }) }}
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
{% endblock %}
