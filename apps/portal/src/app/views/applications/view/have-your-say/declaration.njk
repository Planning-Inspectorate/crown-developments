{% extends "views/layouts/main.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% set title = "Declaration – " + config.haveYourSayServiceName %}
{% block pageTitle %}{{ "Error: " + title if errors else title }}{% endblock %}
  {% if errorSummary and errorSummary.length %}Error: {{ title }}{% else %}{{ title }}{% endif %}

{% block pageHeading %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            <h1 class="govuk-heading-l">
                {{ pageTitle }}
            </h1>
        </div>
    </div>
{% endblock %}
{% block pageContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <p class="govuk-body">
        By submitting this form, you are making a written representation on a Crown
        development application. Your comment will be considered before a decision is made.
      </p>

      <form method="post" novalidate>
        <div class="govuk-form-group {% if errorSummary and errorSummary.length %}govuk-form-group--error{% endif %}">
          <fieldset class="govuk-fieldset" aria-describedby="{% if errorSummary and errorSummary.length %}checkbox-hint{% endif %}">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Confirm each statement</legend>
            <div id="checkbox-hint" class="govuk-hint">
              Select each statement to confirm that you agree.
            </div>

            <div class="govuk-checkboxes" data-module="govuk-checkboxes">
              {% for item in declarationItems %}
                <div class="govuk-checkboxes__item">
                  <input
                    class="govuk-checkboxes__input"
                    id="declaration-{{ item.value }}"
                    name="declaration"
                    type="checkbox"
                    value="{{ item.value }}"
                    {% if item.checked %}checked{% endif %}>
                  <label class="govuk-label govuk-checkboxes__label" for="declaration-{{ item.value }}">
                    {% if item.text %}{{ item.text }}{% else %}{{ item.html | safe }}{% endif %}
                  </label>
                  {% if item.errorMessage and item.errorMessage.text %}
                    <span class="govuk-error-message" id="declaration-{{ item.value }}-error">
                      {{ item.errorMessage.text }}
                    </span>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          </fieldset>
            <br>
        </div>
        <div class="govuk-grid-column-two-thirds">
            <form method="post" novalidate="novalidate">
                {{ govukButton({
                    text: "Accept and submit",
                    type: "submit",
                    preventDoubleClick: true
                }) }}
            </form>
        </div>
{% endblock %}