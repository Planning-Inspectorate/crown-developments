{% extends layoutTemplate %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}

{% set title = "Review representation - " + journeyTitle + " - GOV.UK" %}
{% block pageTitle %}
    {{ title }}
{% endblock %}

{% block content %}

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            <h1 class="govuk-heading-l">
                Does this representation contain potentially distressing content?
            </h1>
        </div>
    </div>

    <form method="POST">
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-full">
                {{  govukRadios({
                    name: 'reviewDistressingContentDecision',
                    value: distressingContentStatus,
                    items: [
                        {
                            value: contentWarning,
                            text: "Yes"
                        },
                        {
                            value: noContentWarning,
                            text: "No"
                        }
                    ],
                    errorMessage: errors.reviewDistressingContentDecision and {
                        text: errors.reviewDistressingContentDecision.msg
                    }
                }) }}
            </div>
        </div>
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-full">
                {{  govukButton({ text: 'Continue' }) }}
            </div>
        </div>
    </form>
{% endblock %}

